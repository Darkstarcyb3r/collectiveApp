rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============ HELPER FUNCTIONS ============

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isGroupMember(groupId) {
      return isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }

    function isGroupCreator(groupId) {
      return isAuthenticated() &&
        request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.creatorId;
    }

    function isConversationParticipant(conversationId) {
      return isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    // ============ USERS ============
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      // Non-owner update rules:
      // Only blockedBy and subscribedUsers can be modified on another user's doc.
      // Each field has per-user validation — you can only add/remove YOUR OWN uid.
      // The 'groups' field is NO LONGER writable by non-owners — group membership
      // syncing is handled server-side by Cloud Functions (admin SDK).
      allow update: if isAuthenticated() && (
        isOwner(userId) ||
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['blockedBy', 'subscribedUsers']) &&
          // --- blockedBy: can only add/remove YOUR OWN uid ---
          (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['blockedBy']) ||
            (
              request.resource.data.blockedBy.toSet().difference(resource.data.blockedBy.toSet()).hasOnly([request.auth.uid]) &&
              resource.data.blockedBy.toSet().difference(request.resource.data.blockedBy.toSet()).hasOnly([request.auth.uid])
            )
          ) &&
          // --- subscribedUsers: can only add/remove YOUR OWN uid ---
          (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['subscribedUsers']) ||
            (
              request.resource.data.subscribedUsers.toSet().difference(resource.data.subscribedUsers.toSet()).hasOnly([request.auth.uid]) &&
              resource.data.subscribedUsers.toSet().difference(request.resource.data.subscribedUsers.toSet()).hasOnly([request.auth.uid])
            )
          )
        )
      );
      allow delete: if false;

      // Private subcollection — stores pushToken and other sensitive data.
      // Only the owner can read/write. Cloud Functions access via admin SDK.
      match /private/{docId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Notifications subcollection
      // SECURITY: Only Cloud Functions (admin SDK) can create notifications.
      // Client-side create is blocked to prevent spoofed/malicious notifications.
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow create: if false;
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    // ============ GROUPS ============
    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.creatorId == request.auth.uid &&
        request.auth.uid in request.resource.data.members;
      // Creator can update anything. Non-creators can only modify members
      // (add/remove themselves), postCount, and updatedAt.
      allow update: if isAuthenticated() && (
        resource.data.creatorId == request.auth.uid ||
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['members', 'postCount', 'updatedAt']) &&
          // members: non-creators can only add/remove their OWN uid
          (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['members']) ||
            (
              request.resource.data.members.toSet().difference(resource.data.members.toSet()).hasOnly([request.auth.uid]) &&
              resource.data.members.toSet().difference(request.resource.data.members.toSet()).hasOnly([request.auth.uid])
            )
          )
        )
      );
      allow delete: if isAuthenticated() && resource.data.creatorId == request.auth.uid;

      // Posts subcollection
      match /posts/{postId} {
        allow read: if isAuthenticated();
        allow create: if isGroupMember(groupId) &&
          request.resource.data.authorId == request.auth.uid;
        allow update: if isAuthenticated() && (
          resource.data.authorId == request.auth.uid ||
          (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['commentCount', 'subscribers']) &&
            // subscribers: non-authors can only add/remove their OWN uid
            (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['subscribers']) ||
              (
                request.resource.data.subscribers.toSet().difference(resource.data.get('subscribers', []).toSet()).hasOnly([request.auth.uid]) &&
                resource.data.get('subscribers', []).toSet().difference(request.resource.data.subscribers.toSet()).hasOnly([request.auth.uid])
              )
            )
          )
        );
        allow delete: if isAuthenticated() && (
          resource.data.authorId == request.auth.uid ||
          isGroupCreator(groupId)
        );

        // Comments subcollection
        match /comments/{commentId} {
          allow read: if isAuthenticated();
          allow create: if isGroupMember(groupId) &&
            request.resource.data.authorId == request.auth.uid;
          allow update: if isAuthenticated() && resource.data.authorId == request.auth.uid;
          allow delete: if isAuthenticated() && (
            resource.data.authorId == request.auth.uid ||
            isGroupCreator(groupId)
          );
        }
      }
    }

    // ============ CONVERSATIONS ============
    // Messages are auto-deleted after 90 days by Cloud Function (cleanupExpiredMessages)
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() == 2;
      // Participants can update operational fields but CANNOT modify 'participants'
      // (prevents adding third parties to private DMs).
      allow update: if isConversationParticipant(conversationId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['participants']);
      // Conversation deletion only marks as deleted for the requesting user
      // (via 'deleted_${userId}' field update). Full doc delete blocked from client.
      allow delete: if false;

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isConversationParticipant(conversationId);
        allow create: if isConversationParticipant(conversationId) &&
          request.resource.data.senderId == request.auth.uid;
        // Allow participants to update reactions only
        allow update: if isConversationParticipant(conversationId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);
        // Users can only delete their own messages
        allow delete: if isConversationParticipant(conversationId) &&
          resource.data.senderId == request.auth.uid;
      }
    }

    // ============ REPORTS ============
    match /reports/{reportId} {
      // Users can read their own reports (needed for duplicate check)
      allow read: if isAuthenticated() && resource.data.reporterId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.reporterId == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ============ CYBER LOUNGE ROOMS ============
    match /cyberLoungeRooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.hostId == request.auth.uid;
      // Host can update anything. Non-hosts can only update participant
      // tracking fields (join/leave/heartbeat) — cannot modify room name,
      // hostId, expiration, or other room settings.
      allow update: if isAuthenticated() && (
        resource.data.hostId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['participants', 'participantCount', 'heartbeats'])
      );
      allow delete: if isAuthenticated() &&
        resource.data.hostId == request.auth.uid;

      // Chatroom messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() &&
          request.resource.data.senderId == request.auth.uid;
        // Allow authenticated users to update reactions only
        allow update: if isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);
        allow delete: if isAuthenticated() && (
          resource.data.senderId == request.auth.uid ||
          request.auth.uid == get(/databases/$(database)/documents/cyberLoungeRooms/$(roomId)).data.hostId
        );
      }
    }

    // ============ EVENTS ============
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.authorId == request.auth.uid &&
        // Require a valid date timestamp so events are visible to queries and cleaned up properly
        request.resource.data.date is timestamp &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0;
      allow update: if isAuthenticated() && (
        resource.data.authorId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount'])
      );
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;

      // Event comments subcollection
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() &&
          request.resource.data.authorId == request.auth.uid;
        allow update: if isAuthenticated() && resource.data.authorId == request.auth.uid;
        allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
      }
    }

    // ============ MUTUAL AID GROUPS ============
    match /mutualAidGroups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.authorId == request.auth.uid;
      // Author can update anything (name, link, description, etc.).
      // Non-authors can only update vettedBy (vote) and commentCount.
      allow update: if isAuthenticated() && (
        resource.data.authorId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['vettedBy', 'commentCount'])
      );
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;

      // Mutual aid comments subcollection
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() &&
          request.resource.data.authorId == request.auth.uid;
        allow update: if isAuthenticated() && resource.data.authorId == request.auth.uid;
        allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
      }
    }

    // ============ BARTER MARKET POSTS ============
    match /barterMarketPosts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.authorId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }

    // ============ CONFLUENCE POSTS ============
    match /confluencePosts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.authorId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }

    // ============ ADMIN TOKENS ============
    // Admins can write their own token; Cloud Functions read all tokens
    match /adminTokens/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // ============ DELETED ACCOUNTS (audit log) ============
    match /deletedAccounts/{docId} {
      allow read: if false;
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    // ============ RATE LIMITS ============
    // Users can read their own rate limit doc (for counter display).
    // Only Cloud Functions (Admin SDK) can write — prevents users from
    // resetting their own counters to bypass spam limits.
    match /rateLimits/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }
  }
}
